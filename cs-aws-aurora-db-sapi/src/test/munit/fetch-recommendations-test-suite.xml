<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit"
	xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core"
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">
	<munit:config name="cs-aws-aurora-db-sapi-test-suite.xml" />
	<munit:test
		name="cs-aws-aurora-db-sapi-fetch-recommendations-test-suite"
		doc:id="d1e82e2a-bdf1-4ba0-af8d-f7fac0cace2c" description="Test">
		<munit:behavior>
			<munit-tools:mock-when doc:name="DB Select"
				doc:id="5513e34e-3dea-4bed-810f-2cce3d30804d" processor="db:select">
				<munit-tools:with-attributes>
					<munit-tools:with-attribute
						whereValue="6587b841-91e0-4317-b2a8-14003fc157ce"
						attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:payload value="#[output application/json --- readUrl('classpath://fetchRecommendations/set-payload-db-response.dwl')]" mediaType="application/json" encoding="UTF-8" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<munit:set-event doc:name="var: initialPayload" doc:id="ffcb573e-f88d-4f15-a782-f5f7e41c6387" >
				<munit:variables >
					<munit:variable key="initialPayload" value="#[output application/java --- readUrl('classpath://fetchRecommendations/set-event-var-initialPayload.dwl')]" encoding="UTF-8" mediaType="application/java" />
				</munit:variables>
			</munit:set-event>
			<flow-ref doc:name="Flow-ref to post:\recommendations:application\json:cs-aws-aurora-db-sapi-config" doc:id="816aab2f-697b-44c9-981c-b2b4159544db" name="post:\recommendations:application\json:cs-aws-aurora-db-sapi-config"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:verify-call doc:name="End Logger" doc:id="6003ad9d-4f8b-4034-adab-b15f9d52c856" processor="logger" atLeast="1">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="7bdea93a-3b10-4c68-8d14-7b86692e52fb" attributeName="doc:id" />
				</munit-tools:with-attributes>
			</munit-tools:verify-call>
		</munit:validation>
	</munit:test>


</mule>
