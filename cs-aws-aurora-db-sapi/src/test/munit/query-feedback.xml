<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit" xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core" xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">
	<munit:config name="cs-aws-aurora-db-sapi-test-suite.xml" />
	<munit:test name="cs-aws-aurora-db-sapi-feedback-query-test-suite" doc:id="85b6a219-d87b-4ffe-acb7-ce4ccf993b90" description="Test">
		<munit:behavior >
			<munit-tools:mock-when doc:name="DB Select" doc:id="c70fda37-3b68-475a-897d-2f7cb97c401a" processor="db:select">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="1565155d-04e5-4413-9df4-34aac3598621" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:payload value="#[output application/json --- readUrl('classpath://queryFeedback/set-payload-db-response.dwl')]" mediaType="application/json" encoding="UTF-8" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<munit:set-event doc:name="Set Event" doc:id="3accb606-2d3b-4c7d-8c91-ad952e430021" >
				<munit:variables >
					<munit:variable key="initialPayload" value="#[output application/java --- readUrl('classpath://queryFeedback/set-event-var-initialPayload.dwl')]" encoding="UTF-8" mediaType="application/java" />
				</munit:variables>
			</munit:set-event>
			<flow-ref doc:name="Flow-ref to post:\feedback\query:application\json:cs-aws-aurora-db-sapi-config" doc:id="ff101e36-08d2-497d-9a19-94358d7f9c9a" name="post:\feedback\query:application\json:cs-aws-aurora-db-sapi-config"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:verify-call doc:name="End Logger" doc:id="d3fa3869-98db-43ad-8e4a-8437015af027" processor="logger" atLeast="1">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="5c61b263-0756-4b7d-9cf0-a1933e732740" attributeName="doc:id" />
				</munit-tools:with-attributes>
			</munit-tools:verify-call>
		</munit:validation>
	</munit:test>


</mule>
